# Copy this file to .env and fill in your values.
# .env is gitignored - never commit real keys.
#
# Vite exposes variables prefixed with VITE_ to the frontend bundle.
# Only use VITE_ prefix for truly public keys (e.g. a map tile ID).
# Secret keys (API tokens, service credentials) must stay server-side only.

# VITE_PUBLIC_MAP_KEY=your_public_key_here
# SOME_SECRET_KEY=never_expose_this_in_frontend_code
